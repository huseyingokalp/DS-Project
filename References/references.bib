  keywords = {Smart agriculture},
  booktitle = {2025 international conference on data science and business systems (ICDSBS)}
}
@inproceedings{shahnawazj2025,
  author = {Mohammad Shahnawaz Shaikh AND Ashwini Kumar Jha AND Brij Raj Soni AND Rasna Nikunj Kumar Patel AND Dhanya PM},
  title = {Flying edge intelligence: UAV-Driven edge computing for autonomous precision farming},
  abstract = {Traditional and cloud-based agriculture face major obstacles due to expanding worldwide populations together with environmental changes along with scarce resources available The paper presents Flying-Edge Computing along with UAVs as an IoT-supported solution that enables AIpowered real-time farming operations within remote areas with weak connectivity. Edge-based data processing occurs on UAVs equipped with advanced sensors and edge AI models which enables persistent disease identification together with irrigation predictions along with independent actuation without relying on continuous cloud services. The proposed system outperforms conventional methods in latency, energy efficiency, scalability, and responsiveness. During field tests in tomato farming operations achieved disease monitoring accuracy rates above 92\% while saving considerable amounts of water. After FlyingEdge Computing, the process of smart agriculture delivers sustainability together with automation and data-driven decisions for remote farming operations to establish nextgeneration farming systems with resilience.},
  pages = {1-6},
  year = {2025},
